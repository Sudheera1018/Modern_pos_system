@model List<CategoryListItemViewModel>
@{
    ViewData["Title"] = "Categories";
}

<div class="modern-card p-4">
    <div class="section-header">
        <div>
            <h2 class="section-title">Categories</h2>
            <p class="section-subtitle">Group products for reporting, filtering, and retail organization.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">Add Category</a>
    </div>

    <div class="table-responsive">
        <table class="table table-modern mb-0">
            <thead>
                <tr>
                    <th>Category</th>
                    <th>Description</th>
                    <th>Products</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@item.CategoryName</div>
                        <div class="small text-secondary">@item.CategoryId</div>
                    </td>
                    <td>@item.Description</td>
                    <td>@item.ProductCount</td>
                    <td><span class="badge-soft @(item.IsActive ? "badge-instock" : "badge-out")">@(item.IsActive ? "Active" : "Inactive")</span></td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-outline-danger">Remove</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
