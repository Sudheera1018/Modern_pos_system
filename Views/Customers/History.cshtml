@model List<SalesHistoryItemViewModel>
@{
    var customer = ViewBag.Customer as CustomerFormViewModel;
    ViewData["Title"] = "Customer Purchase History";
}

<div class="modern-card p-4">
    <div class="section-header">
        <div>
            <h2 class="section-title">Purchase History</h2>
            <p class="section-subtitle">@customer?.FullName (@customer?.CustomerCode)</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to Customers</a>
    </div>

    <div class="table-responsive">
        <table class="table table-modern mb-0">
            <thead><tr><th>Invoice</th><th>Date</th><th>Cashier</th><th>Payment</th><th>Total</th><th></th></tr></thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.InvoiceNo</td>
                    <td>@item.SaleDate.ToString("dd MMM yyyy HH:mm")</td>
                    <td>@item.CashierName</td>
                    <td>@item.PaymentMethod</td>
                    <td>@item.GrandTotal.ToString("C")</td>
                    <td class="text-end"><a asp-controller="SalesHistory" asp-action="Invoice" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Invoice</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
