@model InventoryOverviewViewModel
@{
    ViewData["Title"] = "Inventory";
}

<div class="row g-4">
    <div class="col-12">
        <div class="modern-card p-4">
            <div class="section-header">
                <div>
                    <h2 class="section-title">Stock Overview</h2>
                    <p class="section-subtitle">Current stock, reorder monitoring, and movement visibility.</p>
                </div>
                <a asp-action="Adjustment" class="btn btn-primary">New Stock Adjustment</a>
            </div>

            <div class="row g-4 mb-3">
                <div class="col-md-4"><div class="glass-card p-3"><small class="text-secondary">Tracked Products</small><div class="fs-3 fw-bold">@Model.Products.Count</div></div></div>
                <div class="col-md-4"><div class="glass-card p-3"><small class="text-secondary">Low Stock</small><div class="fs-3 fw-bold">@Model.LowStockProducts.Count</div></div></div>
                <div class="col-md-4"><div class="glass-card p-3"><small class="text-secondary">Out of Stock</small><div class="fs-3 fw-bold">@Model.OutOfStockProducts.Count</div></div></div>
            </div>

            <div class="table-responsive">
                <table class="table table-modern mb-0">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Category</th>
                            <th>Stock</th>
                            <th>Reorder</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Products)
                    {
                        var badgeClass = item.StockStatus switch
                        {
                            "Out of Stock" => "badge-out",
                            "Low Stock" => "badge-low",
                            _ => "badge-instock"
                        };
                        <tr>
                            <td>@item.ProductName <div class="small text-secondary">@item.ProductCode</div></td>
                            <td>@item.CategoryName</td>
                            <td>@item.CurrentStock</td>
                            <td>@item.ReorderLevel</td>
                            <td><span class="badge-soft @badgeClass">@item.StockStatus</span></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-6">
        <div class="modern-card p-4">
            <h3 class="section-title mb-3">Low Stock Watchlist</h3>
            <div class="table-responsive">
                <table class="table table-modern mb-0">
                    <thead><tr><th>Product</th><th>Stock</th><th>Reorder</th></tr></thead>
                    <tbody>
                    @foreach (var item in Model.LowStockProducts)
                    {
                        <tr><td>@item.ProductName</td><td>@item.CurrentStock</td><td>@item.ReorderLevel</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-12 col-xl-6">
        <div class="modern-card p-4">
            <h3 class="section-title mb-3">Recent Inventory Movements</h3>
            <div class="table-responsive">
                <table class="table table-modern mb-0">
                    <thead><tr><th>Product</th><th>Type</th><th>Qty</th><th>Reference</th></tr></thead>
                    <tbody>
                    @foreach (var item in Model.Movements)
                    {
                        <tr><td>@item.ProductName</td><td>@item.MovementType</td><td>@item.Quantity</td><td>@item.ReferenceNo</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
