@model ProductFormViewModel
@{
    ViewData["Title"] = string.IsNullOrWhiteSpace(Model.Id) ? "Add Product" : "Edit Product";
}

<div class="modern-card p-4">
    <div class="section-header">
        <div>
            <h2 class="section-title">@ViewData["Title"]</h2>
            <p class="section-subtitle">Capture sellable product details and POS inventory rules.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>

    <form asp-action="@(string.IsNullOrWhiteSpace(Model.Id) ? "Create" : "Edit")" method="post" enctype="multipart/form-data" class="row g-3">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div class="col-md-4">
            <label asp-for="ProductId" class="form-label"></label>
            <input asp-for="ProductId" class="form-control" />
            <span asp-validation-for="ProductId" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="ProductCode" class="form-label"></label>
            <input asp-for="ProductCode" class="form-control" />
            <span asp-validation-for="ProductCode" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Barcode" class="form-label"></label>
            <input asp-for="Barcode" class="form-control" />
            <span asp-validation-for="Barcode" class="text-danger small"></span>
        </div>
        <div class="col-12">
            <label asp-for="ProductName" class="form-label"></label>
            <input asp-for="ProductName" class="form-control" />
            <span asp-validation-for="ProductName" class="text-danger small"></span>
        </div>
        <div class="col-12">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>
        <div class="col-md-6">
            <label asp-for="CategoryId" class="form-label"></label>
            <select asp-for="CategoryId" class="form-select" asp-items="@(new SelectList(Model.Categories, "Id", "Name"))"></select>
            <span asp-validation-for="CategoryId" class="text-danger small"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="SupplierId" class="form-label"></label>
            <select asp-for="SupplierId" class="form-select" asp-items="@(new SelectList(Model.Suppliers, "Id", "Name"))"></select>
            <span asp-validation-for="SupplierId" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="CostPrice" class="form-label"></label>
            <input asp-for="CostPrice" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="SellingPrice" class="form-label"></label>
            <input asp-for="SellingPrice" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="CurrentStock" class="form-label"></label>
            <input asp-for="CurrentStock" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="ReorderLevel" class="form-label"></label>
            <input asp-for="ReorderLevel" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="ForecastItemCode" class="form-label"></label>
            <input asp-for="ForecastItemCode" class="form-control" />
            <span asp-validation-for="ForecastItemCode" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="SafetyStock" class="form-label"></label>
            <input asp-for="SafetyStock" class="form-control" />
            <span asp-validation-for="SafetyStock" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="SupplierLeadTimeDays" class="form-label"></label>
            <input asp-for="SupplierLeadTimeDays" class="form-control" />
            <span asp-validation-for="SupplierLeadTimeDays" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Unit" class="form-label"></label>
            <input asp-for="Unit" class="form-control" />
        </div>
        <div class="col-md-6">
            <label asp-for="ImageUrl" class="form-label"></label>
            <input asp-for="ImageUrl" class="form-control" />
        </div>
        <div class="col-md-6">
            <label asp-for="ImageFile" class="form-label"></label>
            <input asp-for="ImageFile" class="form-control" type="file" accept="image/*" />
            <div class="form-text">Upload a product image to Cloudinary, or keep using a direct image URL as fallback.</div>
            <span asp-validation-for="ImageFile" class="text-danger small"></span>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <div class="col-12">
                <div class="product-image-preview">
                    <span class="form-label d-block">Current Image Preview</span>
                    <img src="@Model.ImageUrl" alt="@Model.ProductName" class="img-fluid rounded border" style="max-width: 220px; max-height: 220px; object-fit: cover;" />
                </div>
            </div>
        }
        <div class="col-12">
            <div class="form-check">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>
        </div>
        <div class="col-12 d-flex gap-2">
            <button class="btn btn-primary">Save Product</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
