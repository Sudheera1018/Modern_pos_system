@model PurchaseDetailViewModel
@{
    ViewData["Title"] = "GRN Details";
}

<div class="modern-card p-4">
    <div class="section-header">
        <div>
            <h2 class="section-title">@Model.GrnNumber</h2>
            <p class="section-subtitle">@Model.SupplierName • @Model.GrnDate.ToString("dd MMM yyyy")</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>

    <div class="table-responsive">
        <table class="table table-modern mb-0">
            <thead><tr><th>Product</th><th>Qty</th><th>Cost Price</th><th>Line Total</th></tr></thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                <tr><td>@item.ProductName</td><td>@item.Quantity</td><td>@item.CostPrice.ToString("C")</td><td>@item.LineTotal.ToString("C")</td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
