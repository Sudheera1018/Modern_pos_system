@model RolePermissionMatrixViewModel
@{
    ViewData["Title"] = "Role Permissions";
}

<div class="modern-card p-4">
    <div class="section-header">
        <div>
            <h2 class="section-title">Form Access Management</h2>
            <p class="section-subtitle">Control which modules appear in the sidebar and which screens each role can open.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Roles" class="btn btn-outline-secondary">Manage Roles</a>
            <a asp-action="CreateRole" class="btn btn-primary">Create Role</a>
        </div>
    </div>

    <form method="get" class="mb-4">
        <select name="roleId" class="form-select" onchange="this.form.submit()">
            @foreach (var role in Model.Roles)
            {
                if (Model.RoleId == role.Id)
                {
                    <option value="@role.Id" selected>@role.Name</option>
                }
                else
                {
                    <option value="@role.Id">@role.Name</option>
                }
            }
        </select>
    </form>

    <form asp-action="SavePermissions" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="RoleId" type="hidden" />
        <div class="table-responsive">
            <table class="table table-modern mb-0">
                <thead><tr><th>Module</th><th>Icon</th><th>Access</th></tr></thead>
                <tbody>
                @for (var i = 0; i < Model.Permissions.Count; i++)
                {
                    <tr>
                        <td>
                            @Model.Permissions[i].FormName
                            <input asp-for="Permissions[i].FormKey" type="hidden" />
                            <input asp-for="Permissions[i].FormName" type="hidden" />
                            <input asp-for="Permissions[i].Icon" type="hidden" />
                        </td>
                        <td><i class="@Model.Permissions[i].Icon"></i></td>
                        <td><input asp-for="Permissions[i].CanAccess" class="form-check-input" /></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <div class="mt-4">
            <button class="btn btn-primary">Save Permissions</button>
        </div>
    </form>
</div>
