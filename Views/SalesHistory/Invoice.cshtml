@model InvoiceViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Invoice";
}

<div class="modern-card p-4">
    <div class="section-header">
        <div>
            <h2 class="section-title">Invoice @Model.InvoiceNo</h2>
            <p class="section-subtitle">@Model.SaleDate.ToString("dd MMM yyyy HH:mm") | @Model.CustomerName</p>
        </div>
        <button class="btn btn-primary" onclick="window.print()">Print Invoice</button>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4"><div class="glass-card p-3"><small class="text-secondary">Cashier</small><div class="fw-bold">@Model.CashierName</div></div></div>
        <div class="col-md-4"><div class="glass-card p-3"><small class="text-secondary">Payment</small><div class="fw-bold">@Model.PaymentMethod</div></div></div>
        <div class="col-md-4"><div class="glass-card p-3"><small class="text-secondary">Net Payable</small><div class="fw-bold">@Model.NetPayable.ToString("C")</div></div></div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4"><div class="glass-card p-3"><small class="text-secondary">Loyalty Redeemed</small><div class="fw-bold">@Model.LoyaltyAmountRedeemed.ToString("C") (@Model.LoyaltyPointsRedeemed.ToString("N0") pts)</div></div></div>
        <div class="col-md-4"><div class="glass-card p-3"><small class="text-secondary">Loyalty Earned</small><div class="fw-bold">@Model.LoyaltyPointsEarned.ToString("N0") pts</div></div></div>
        <div class="col-md-4"><div class="glass-card p-3"><small class="text-secondary">Paid Amount</small><div class="fw-bold">@Model.AmountReceived.ToString("C")</div></div></div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4"><div class="glass-card p-3"><small class="text-secondary">Cash</small><div class="fw-bold">@Model.CashPaidAmount.ToString("C")</div></div></div>
        <div class="col-md-4"><div class="glass-card p-3"><small class="text-secondary">Card</small><div class="fw-bold">@Model.CardPaidAmount.ToString("C")</div><small class="text-secondary">@Model.CardReference</small></div></div>
        <div class="col-md-4"><div class="glass-card p-3"><small class="text-secondary">Fund Transfer</small><div class="fw-bold">@Model.FundTransferAmount.ToString("C")</div><small class="text-secondary">@($"{Model.TransferProvider} {Model.TransferReferenceNo}".Trim())</small></div></div>
    </div>

    <div class="table-responsive mb-4">
        <table class="table table-modern mb-0">
            <thead><tr><th>Product</th><th>Qty</th><th>Unit Price</th><th>Discount</th><th>Total</th></tr></thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td>@item.Quantity</td>
                    <td>@item.UnitPrice.ToString("C")</td>
                    <td>@item.DiscountAmount.ToString("C")</td>
                    <td>@item.LineTotal.ToString("C")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="ms-auto" style="max-width: 360px;">
        <div class="d-flex justify-content-between mb-2"><span>Subtotal</span><strong>@Model.Subtotal.ToString("C")</strong></div>
        <div class="d-flex justify-content-between mb-2"><span>Discount</span><strong>@Model.DiscountTotal.ToString("C")</strong></div>
        <div class="d-flex justify-content-between mb-2"><span>Tax</span><strong>@Model.TaxAmount.ToString("C")</strong></div>
        <div class="d-flex justify-content-between mb-2"><span>Loyalty Redeemed</span><strong>-@Model.LoyaltyAmountRedeemed.ToString("C")</strong></div>
        <div class="d-flex justify-content-between border-top pt-2"><span class="fw-bold">Net Payable</span><strong>@Model.NetPayable.ToString("C")</strong></div>
    </div>
</div>
