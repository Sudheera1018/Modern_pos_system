@using ModernPosSystem.Helpers
@inject ICurrentUserContext CurrentUser
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Modern POS System</title>
    <link rel="icon" type="image/png" href="~/favicon.png" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-body">
    @if (CurrentUser.IsAuthenticated)
    {
        <div class="app-shell" id="appShell">
            <aside class="sidebar-panel" id="sidebarPanel">
                @await Component.InvokeAsync("Sidebar")
            </aside>
            <div class="main-panel">
                @await Html.PartialAsync("_TopNavbar")
                <main class="content-panel">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <main class="auth-host">
            @RenderBody()
        </main>
    }

    @await Html.PartialAsync("_ToastMessages")

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
